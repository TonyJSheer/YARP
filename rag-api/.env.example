DATABASE_URL=postgresql://rag:rag@localhost:5432/rag
ANTHROPIC_API_KEY=sk-ant-your-key-here
EMBED_MODEL=all-mpnet-base-v2
UPLOAD_DIR=./data/uploads

# Auth
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# MCP stdio transport — set this in your MCP client config (Claude Desktop / Claude Code)
# Generate a token: JWT_SECRET=<secret> uv run python scripts/generate_token.py <account_id>
MCP_AUTH_TOKEN=

# Storage backend: local (default) or s3
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=us-east-1
# S3_ENDPOINT_URL: leave blank for standard AWS S3.
# Set to the Fly Tigris endpoint when deploying to Fly.io (set automatically by `fly storage create`).
# Example: https://fly.storage.tigris.dev
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Redis (async ingestion worker)
REDIS_URL=redis://localhost:6379/0
